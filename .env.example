# ────────────────────────────────────────────────────────────────
# NUTTER-XMD — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
# Use Supabase (recommended) or any PostgreSQL database
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Fallback local database (set automatically by Replit)
# DATABASE_URL=postgresql://...

# ── Authentication (Clerk) ────────────────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Sessions ─────────────────────────────────────────────────────
# Random secret string — generate with: openssl rand -base64 32
SESSION_SECRET=your-random-secret-here

# ── AI Features (OpenAI) ─────────────────────────────────────────
# Provided automatically by Replit AI Integrations.
# On Vercel, get these from https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Frontend API URL ─────────────────────────────────────────────
# On Vercel: leave empty (API is on the same domain at /api)
# For separate deployments: set to your API server URL
# VITE_API_URL=https://your-api-server.com

# ── Replit-specific (set automatically on Replit) ─────────────────
# PORT=8099
# BASE_PATH=/nutter-xmd/nutter-xmd-old
